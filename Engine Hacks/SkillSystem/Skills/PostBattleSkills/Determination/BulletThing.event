DoppioEvent:
//doppio skill uses flags: 0xA3, 0xA4, 0xA5
//if 0xA5 is on (max stacks), auto end
CHECK_EVENTID 0xA5
BNE 0x776 0xC 0x0

//2 bullets
CHECK_EVENTID 0xA3
BEQ 0x3 0xC 0x0
ENUF 0xA3
ENUT 0xA4
GOTO 0x776

LABEL 0x3
ENUT 0xA3
//3 bullets
CHECK_EVENTID 0xA4
BEQ 0x776 0xC 0x0

ENUF 0xA3
ENUF 0xA4
ENUT 0xA5
SOUN 0xF0 //legendary weapon shine
STAL 0x32

LABEL 0x776 //end
NoFade
ENDA
